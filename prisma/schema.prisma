generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  password         String
  nombre           String?
  salario          Float?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  gastos           Gasto[]
  salarioHistorial SalarioHistorial[]
}

model Gasto {
  id          String   @id @default(cuid())
  descripcion String
  monto       Float
  categoria   String
  fecha       DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([fecha])
  @@index([categoria])
}

model SalarioHistorial {
  id              String   @id @default(cuid())
  salario         Float
  inflacion       Float    @default(0)
  salarioAjustado Float
  fecha           DateTime @default(now())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
